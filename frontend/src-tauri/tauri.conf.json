{
  "productName": "hello-world",
  "version": "0.1.0",
  "identifier": "com.hello-world.app",
  "build": {
    "beforeDevCommand": "npm run dev -- -p 3002",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:3002",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "title": "HELLO WORLD",
        "width": 1200,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
